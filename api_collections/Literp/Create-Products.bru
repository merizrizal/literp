meta {
  name: Create-Product
  type: http
  seq: 9
}

post {
  url: http://{{host}}:{{port}}/api/v1/products
  body: json
  auth: inherit
}

body:json {
  {
    "sku": "{{productSku}}",
    "name": "Widget A",
    "productType": "STOCK",
    "baseUom": "{{uomId}}",
    "metadata": {
      "weight": 2.5,
      "weight_unit": "kg",
      "color": "blue"
    }
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
