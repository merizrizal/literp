SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
export ROOT_DIR="$(cd "$SCRIPT_DIR/../.." && pwd)"

export DB_USER=${TEST_DB_USER:-root}
export DB_PASSWORD=${TEST_DB_PASSWORD:-pgdevpassword}
export DB_HOST=${TEST_DB_HOST:-127.0.0.1}
export DB_PORT=${TEST_DB_PORT:-55432}
export DB_NAME=${TEST_DB_NAME:-literp_test}
export DB_URL="postgresql://$DB_USER:$DB_PASSWORD@$DB_HOST:$DB_PORT/$DB_NAME"
